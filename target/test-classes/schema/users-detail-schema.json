{
  "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["id", "name", "username", "email"],
    "properties": {
      "id": {
        "type": "integer"
      },
      "name": {
        "type": "object"
      },
      "username": {
        "type": "string"
      },
      "email": {
        "type": "string",
        "pattern": "^.+@.+\\..+$"
      },
      "phone": {
        "type": "string"
      },
      "password": {
        "type": "string"
      },
      "address": {
        "type": "object"
      }
    }
}